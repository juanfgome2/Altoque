{
    "hosting":  {
                    "public":  ".",
                    "ignore":  [
                                   "firebase.json",
                                   ".firebaserc",
                                   "**/.*",
                                   "**/node_modules/**",
                                   "functions/**",
                                   "android/**",
                                   "www/**",
                                   "package.json",
                                   "package-lock.json",
                                   "capacitor.config.json",
                                   "README.md",
                                   "dev-server.ps1",
                                   "firebase.rules",
                                   "firebase-debug.log",
                                   "firebase-debug.*.log"
                               ]
                },
    "functions":  [
                      {
                          "source":  "functions",
                          "codebase":  "default",
                          "disallowLegacyRuntimeConfig":  true,
                          "ignore":  [
                                         "node_modules",
                                         ".git",
                                         "firebase-debug.log",
                                         "firebase-debug.*.log",
                                         "*.local"
                                     ],
                          "predeploy":  [
                                            "npm --prefix \"$RESOURCE_DIR\" run lint"
                                        ]
                      }
                  ],
    "firestore":  {
                      "rules":  "firebase.rules"
                  }
}
