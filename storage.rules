rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isImageUnder5Mb() {
      return request.resource != null &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size <= 5 * 1024 * 1024;
    }

    match /orderImages/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId && isImageUnder5Mb();
    }

    match /profilePhotos/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId && isImageUnder5Mb();
      allow delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
